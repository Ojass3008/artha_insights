# Public — exposed to the browser, safe by Supabase RLS
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Access key for the internal /allocator page (soft gate). If unset, the page
# is open. Set the same value in Vercel to protect it in production.
VITE_ALLOCATOR_KEY=

# Optional token for the live /api/allocate endpoint. If you set
# ALLOCATE_API_TOKEN (server, in Vercel), also set this matching public value
# so the dashboard's "Run live analysis" button can call it. Leave both unset
# to keep the endpoint open.
VITE_ALLOCATE_API_TOKEN=

# Server-only — never committed, set in Vercel dashboard
SUPABASE_SERVICE_ROLE_KEY=

# Resend email sending
RESEND_API_KEY=

# FROM address for brief emails. Once you verify your domain in Resend,
# set this to e.g. "Artha Insights <briefs@yourdomain.com>".
# Falls back to Resend's shared test domain if unset (hits spam — fix this).
BRIEF_FROM_EMAIL=
BRIEF_REPLY_TO=

# Shared secret protecting the cron endpoints (api/cron/*). Vercel cron sends
# a vercel-cron user-agent and is allowed automatically; this secret lets you
# trigger the jobs manually via ?secret=... or an Authorization: Bearer header.
CRON_SECRET=
